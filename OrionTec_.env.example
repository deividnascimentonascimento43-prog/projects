# Orion Tec — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores

PORT=3000
FRONTEND_URL=https://oriontec.com.br

# Chave secreta JWT (mude para algo aleatório e longo!)
JWT_SECRET=mude_para_algo_secreto_aqui_123!@#

# E-mail SMTP (Gmail, Sendgrid, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@gmail.com
SMTP_PASS=sua_senha_de_app_gmail

# E-mail do administrador para receber mensagens de contato
ADMIN_EMAIL=contato@oriontec.com.br
